# Claude CLI auth (from `claude setup-token`)
CLAUDE_CODE_OAUTH_TOKEN="sk-ant-oat01-..."

# GitHub auth token (from `gh auth token`)
GH_TOKEN=

# Optional: override claude binary path
# CLAUDE_BIN="/path/to/claude"

# Innies proxy (optional)
# Set to "true" to route claude calls through innies proxy
# Requires: npm install -g innies
# USE_INNIES=true
# INNIES_TOKEN=in_live_...
