/* Forge CLI — Dark theme with Claude Code-inspired styling */

Screen {
    background: #1a1a2e;
    color: #e0e0e0;
}

#header-bar {
    dock: top;
    height: 1;
    background: #6c3fc5;
    color: #ffffff;
    text-style: bold;
    padding: 0 1;
}

#main {
    height: 1fr;
}

#left-col {
    width: 3fr;
    height: 1fr;
    border-right: solid #3a3a5c;
}

StatusPanel {
    width: 1fr;
    height: 1fr;
    padding: 1;
    overflow-y: auto;
    border: round #3a3a5c;
    background: #16162a;
}

#status-header {
    height: auto;
    text-style: bold;
    color: #6c3fc5;
    margin-bottom: 1;
}

#status-content {
    height: auto;
    padding: 0 1;
    color: #808090;
}

/* Log Panel */

LogPanel {
    height: 1fr;
    max-height: 50%;
    border-top: solid #3a3a5c;
    background: #16162a;
}

LogPanel TabbedContent {
    height: 1fr;
}

LogPanel ContentSwitcher {
    height: 1fr;
}

LogPanel TabPane {
    height: 1fr;
    padding: 0;
}

_LogView {
    height: 1fr;
}

_LogView VerticalScroll {
    height: 1fr;
    background: #1a1a2e;
    padding: 0 1;
}

#log-empty {
    height: auto;
    padding: 1;
    color: #808090;
}
