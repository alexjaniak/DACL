/* Event feed panel styles — to be merged into layout.tcss */

EventFeed {
    width: 1fr;
    height: 1fr;
    border: round #3a3a5c;
    background: #16162a;
}

#event-feed-header {
    height: auto;
    text-style: bold;
    color: #6c3fc5;
    padding: 1 1 0 1;
    margin-bottom: 1;
}

#event-feed-scroll {
    height: 1fr;
    padding: 0 1;
}

#event-feed-content {
    height: auto;
    color: #c0c0d0;
}
